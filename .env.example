# Lead Profiler — Environment Variables
#
# On the Z.ai sandbox, the app uses z-ai-web-dev-sdk automatically (reads /etc/.z-ai-config).
# On Vercel or any other host, set these env vars to use any OpenAI-compatible API.

# Required for Vercel deployment — any OpenAI-compatible API key
OPENAI_API_KEY=

# Optional — defaults to https://api.openai.com/v1
# Use this for OpenRouter, Together, Anyscale, Ollama, etc.
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional — defaults to gpt-4o-mini
# For better Arabic output, consider: gpt-4o, anthropic/claude-3.5-sonnet, etc.
# OPENAI_MODEL=gpt-4o-mini

# Optional — Prisma database (only needed if you add persistence later)
DATABASE_URL=file:./dev.db
